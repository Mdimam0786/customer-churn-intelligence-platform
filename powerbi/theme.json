{
  "name": "Churn Intelligence Platform Theme",
  "dataColors": [
    "#1F4E79",
    "#D62728",
    "#2CA02C",
    "#FF7F0E",
    "#9467BD",
    "#8C564B",
    "#17BECF",
    "#7F7F7F"
  ],
  "background": "#FFFFFF",
  "foreground": "#1A1A1A",
  "tableAccent": "#1F4E79",
  "good": "#2CA02C",
  "neutral": "#FF7F0E",
  "bad": "#D62728",
  "maximum": "#D62728",
  "center": "#FF7F0E",
  "minimum": "#2CA02C",
  "textClasses": {
    "callout": { "fontSize": 32, "fontFace": "Segoe UI Semibold", "color": "#1F4E79" },
    "title": { "fontSize": 14, "fontFace": "Segoe UI Semibold", "color": "#1A1A1A" },
    "label": { "fontSize": 10, "fontFace": "Segoe UI", "color": "#4D4D4D" }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [{ "color": { "solid": { "color": "#FFFFFF" } }, "transparency": 0 }],
        "border": [{ "show": true, "color": { "solid": { "color": "#E6E6E6" } } }]
      }
    },
    "card": {
      "*": {
        "labels": [{ "color": { "solid": { "color": "#1F4E79" } }, "fontSize": 32 }]
      }
    }
  }
}
